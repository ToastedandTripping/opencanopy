{
  "name": "opencanopy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build-tiles": "npx tsx scripts/build-tiles.ts",
    "build-tiles:test": "npx tsx scripts/build-tiles.ts --region 5,5",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "audit:rendering": "vitest run --reporter=verbose src/test/audit/",
    "audit:tiles": "npx tsx scripts/audit-tiles.ts",
    "audit": "npm run audit:rendering && npm run audit:tiles",
    "audit:spatial": "npx tsx scripts/audit-spatial.ts",
    "audit:temporal": "npx tsx scripts/audit-temporal.ts",
    "audit:crosssource": "python3 scripts/audit-crosssource.py",
    "audit:visual": "npx playwright test e2e/screenshots/",
    "audit:visual:update": "npx playwright test e2e/screenshots/ --update-snapshots",
    "audit:live": "npx playwright test e2e/monitoring/",
    "audit:download-reference": "npx tsx scripts/download-reference-data.ts",
    "audit:v2": "npm run audit && npm run audit:spatial",
    "//audit:v2-note": "audit:visual is intentionally excluded from audit:v2 — it requires a running dev server. Run audit:visual separately.",
    "audit:full": "npm run audit:v2 && npm run audit:temporal",
    "test:tile-config": "npx tsx scripts/test-tile-config.ts",
    "sweep:tile-configs": "npx tsx scripts/sweep-tile-configs.ts",
    "preprocess": "NODE_OPTIONS='--max-old-space-size=8192' npx tsx scripts/preprocess-tiles.ts",
    "preprocess:validate-only": "npx tsx scripts/preprocess-tiles.ts --validate-only",
    "build-tiles:full": "npm run preprocess && npm run build-tiles -- --tiles-only --audit",
    "audit:fidelity": "npx tsx scripts/audit-source-fidelity.ts",
    "audit:precision": "npx tsx scripts/audit-geometry-precision.ts",
    "audit:adversarial": "npx tsx scripts/audit-adversarial.ts",
    "audit:crosssource-lite": "npx tsx scripts/audit-crosssource-lite.ts",
    "audit:trend": "npx tsx scripts/audit-trend.ts",
    "audit:property-deep": "npx tsx scripts/audit-property-deep.ts",
    "audit:all": "npx tsx scripts/audit-all.ts",
    "audit:ci": "npx tsx scripts/audit-all.ts --ci --fail-on-warn"
  },
  "dependencies": {
    "@turf/area": "^7.3.4",
    "@turf/bbox": "^7.3.4",
    "@turf/bbox-polygon": "^7.3.4",
    "@turf/boolean-within": "^7.3.4",
    "@turf/difference": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/intersect": "^7.3.4",
    "maplibre-gl": "^5.21.0",
    "next": "16.2.0",
    "pmtiles": "^4.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
    "scrollama": "^3.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "happy-dom": "^20.8.7",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
