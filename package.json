{
  "name": "opencanopy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build-tiles": "npx tsx scripts/build-tiles.ts",
    "build-tiles:test": "npx tsx scripts/build-tiles.ts --region 5,5",
