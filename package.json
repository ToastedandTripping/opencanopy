    "@turf/helpers": "^7.3.4",
    "@turf/intersect": "^7.3.4",
    "maplibre-gl": "^5.21.0",
    "next": "16.2.0",
    "pmtiles": "^4.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
    "scrollama": "^3.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
