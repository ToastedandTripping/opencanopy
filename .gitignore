# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
deploy.sh

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production

# vercel
.vercel

# netlify
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated tile data (large files, built by scripts/build-tiles.ts)
/data/geojson/
/data/tiles/
/data/progress/
/public/data/tiles/
data/raster/*.tif
data/raster-tiles/

# V2 Diagnostic Pipeline — generated artifacts
e2e/screenshots/baselines/
e2e/screenshots/diffs/
data/geojson/reference/
data/tiles/archive/
data/reports/
